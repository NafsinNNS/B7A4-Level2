model Review {
    id        String   @id @default(uuid())
    rating    Int
    comment   String?
    createdAt DateTime @default(now())

    userId     String
    user       User     @relation(fields: [userId], references: [id])
    propertyId String
    property   Property @relation(fields: [propertyId], references: [id])

    @@map("reviews")
}
